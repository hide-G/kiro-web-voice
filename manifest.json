{
  "manifest_version": 3,
  "name": "Kiro Web Voice (PoC)",
  "short_name": "Kiro Voice",
  "version": "0.3.0",
  "description": "Push-to-talk voice input and optional read-aloud for Kiro Web. Proof-of-concept.",
  "author": "hide-G",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "Kiro Web Voice",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://app.kiro.dev/*"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://app.kiro.dev/*"
  ],
  "commands": {
    "toggle-listening": {
      "suggested_key": {
        "default": "Alt+K",
        "mac": "Alt+K"
      },
      "description": "Toggle push-to-talk"
    },
    "read-latest": {
      "suggested_key": {
        "default": "Alt+Shift+K",
        "mac": "Alt+Shift+K"
      },
      "description": "Read latest agent message"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["src/content/content.css"],
      "matches": ["https://app.kiro.dev/*"]
    }
  ]
}
